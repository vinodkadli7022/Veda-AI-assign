# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# MongoDB - Use MongoDB Atlas (free tier) or local MongoDB
# Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/vedaai-assessment
MONGODB_URI=mongodb://localhost:27017/vedaai-assessment

# Redis - Use Redis Cloud (free tier) or local Redis  
# Redis Cloud: redis://:password@host:port
# Optional - app works without Redis using inline processing fallback
REDIS_URL=redis://localhost:6379

# Google Gemini AI - Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
